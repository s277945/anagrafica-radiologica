{
  "name": "anagrafica-radiologica-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "kubb:gen": "kubb generate",
    "prebuild": "npm run kubb:gen",
    "build": "tsc -b && vite build",
    "pretest": "npm run kubb:gen",
    "test": "vitest run",
    "test:watch": "vitest",
    "precoverage": "npm run kubb:gen",
    "coverage": "vitest run --coverage",
    "pretest:integration": "npm run kubb:gen",
    "test:integration": "playwright test",
    "test:integration:ui": "playwright test --ui",
    "test:integration:headed": "playwright test --headed"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@kubb/cli": "^3.2.0",
    "@kubb/core": "^3.2.0",
    "@kubb/plugin-client": "^3.2.0",
    "@kubb/plugin-oas": "^3.2.0",
    "@kubb/plugin-react-query": "^3.2.0",
    "@kubb/plugin-ts": "^3.2.0",
    "@playwright/test": "^1.47.2",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.0",
    "jsdom": "^24.0.0",
    "sass-embedded": "^1.100.0",
    "typescript": "^5.5.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.0"
  }
}
